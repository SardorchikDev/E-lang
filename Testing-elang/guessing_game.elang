note Simple number guessing game in E-Lang.

say "Welcome to the E-Lang number guessing game."
say "I am thinking of a number from 1 to 10."

let secret be call random_between with 1, 10

let tries be 0
let guessed_it be false

while not guessed_it do
    ask "Enter your guess:" and store in guess
    set tries to tries plus 1

    if guess is less than 1 or guess is greater than 10 then
        say "Please enter a number from 1 to 10."
    else if guess is less than secret then
        say "Too low."
    else if guess is greater than secret then
        say "Too high."
    else
        set guessed_it to true
        say "You guessed it!"
        say "Number of tries:"
        say tries
    end
end
